{
  "layout_name": "admin_attendance_settings",
  "version": "1.0.0",
  "extends": "_admin_base",
  "meta": {
    "title": "$t:yjsoft-attendance.settings.title",
    "auth_required": true
  },
  "data_sources": [
    {
      "id": "settings",
      "type": "api",
      "method": "GET",
      "endpoint": "/api/modules/yjsoft-attendance/admin/settings",
      "auto_fetch": true,
      "auth_required": true,
      "initLocal": "form",
      "refetchOnMount": true
    }
  ],
  "state": {
    "isSaving": false,
    "form": {}
  },
  "slots": {
    "content": [
      {
        "id": "settings_page_wrapper",
        "name": "Div",
        "type": "basic",
        "props": {
          "className": "max-w-4xl mx-auto"
        },
        "children": [
          {
            "id": "settings_page_header",
            "name": "PageHeader",
            "type": "composite",
            "props": {
              "title": "$t:yjsoft-attendance.settings.title"
            }
          },
          {
            "id": "section_general",
            "name": "Card",
            "type": "composite",
            "props": {
              "title": "$t:yjsoft-attendance.settings.general.title",
              "className": "mb-6"
            },
            "children": [
              {
                "id": "field_auto_attend",
                "name": "FormField",
                "type": "composite",
                "props": {
                  "label": "$t:yjsoft-attendance.settings.general.auto_attend"
                },
                "children": [
                  {
                    "id": "toggle_auto_attend",
                    "name": "Toggle",
                    "type": "composite",
                    "props": {
                      "checked": "{{_local.form?.general?.auto_attend ?? false}}",
                      "label": "$t:yjsoft-attendance.settings.general.auto_attend_description"
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "setState",
                        "params": {
                          "target": "local",
                          "form.general.auto_attend": "{{$event.target.checked}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "section_bonus",
            "name": "Card",
            "type": "composite",
            "props": {
              "title": "$t:yjsoft-attendance.settings.bonus.title",
              "className": "mb-6"
            },
            "children": [
              {
                "id": "field_base_point",
                "name": "FormField",
                "type": "composite",
                "props": {
                  "label": "$t:yjsoft-attendance.settings.bonus.base_point"
                },
                "children": [
                  {
                    "id": "input_base_point",
                    "name": "Input",
                    "type": "basic",
                    "props": {
                      "type": "number",
                      "value": "{{_local.form?.bonus?.base_point ?? 0}}",
                      "className": "w-full"
                    },
                    "actions": [
                      {
                        "type": "change",
                        "handler": "setState",
                        "params": {
                          "target": "local",
                          "form.bonus.base_point": "{{Number($event.target.value) || 0}}"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "id": "bonus_streak_grid",
                "name": "Div",
                "type": "basic",
                "props": {
                  "className": "grid grid-cols-1 md:grid-cols-3 gap-4 mt-4"
                },
                "children": [
                  {
                    "id": "field_weekly_streak",
                    "name": "FormField",
                    "type": "composite",
                    "props": {
                      "label": "$t:yjsoft-attendance.settings.bonus.weekly_streak_point"
                    },
                    "children": [
                      {
                        "id": "input_weekly_streak",
                        "name": "Input",
                        "type": "basic",
                        "props": {
